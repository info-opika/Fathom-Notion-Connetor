# Anthropic API Key (https://console.anthropic.com)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Fathom API Key (Fathom Settings -> API Access)
FATHOM_API_KEY=your_fathom_api_key_here

# Notion Integration Token (https://www.notion.so/my-integrations)
# Share your database: database -> ... -> Connections -> add integration
NOTION_TOKEN=ntn_your_notion_integration_token_here

# Notion Database ID (32-char ID from URL, not the full URL)
NOTION_DATABASE_ID=your_notion_database_id_here

# Email digest — use Resend on Render (HTTPS), or Gmail SMTP locally.
# Resend: https://resend.com — verify your domain, then set API key + from address.
RESEND_API_KEY=
EMAIL_FROM=Call Summary Bot <notifications@yourdomain.com>

# Gmail fallback (local dev): Google Account -> Security -> App passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=

# Recipients for daily digest (comma-separated)
TEAM_EMAILS=john@example.com,sarah@example.com

# Scheduler (optional)
SCHEDULE_TIME=09:00
TIMEZONE=America/Chicago

# How far back to fetch Fathom calls in hours (default: 24)
FATHOM_LOOKBACK_HOURS=24

# Secret for FastCron daily job: GET /run?secret=YOUR_VALUE
CRON_SECRET=generate_a_long_random_string_here
